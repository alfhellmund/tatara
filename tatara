#!/usr/bin/env bash
# tatara — Bootstrap fuer neue Projekte: git + Beads + Claude-Workflow
# Autor: Alf Hellmund · MIT-Lizenz
#
# Modi:
#   tatara <NAME> [BESCHREIBUNG]  Neues Projekt unter ~/Development/<NAME> anlegen
#   tatara --check                Globale Voraussetzungen + optionale KI-CLIs pruefen
#   tatara --bootstrap-globals    Fehlende globale ~/.claude/* Dateien anlegen
#   tatara --snapshot-globals     Aktuelle ~/.claude/* Dateien als Templates sichern
#   tatara -h | --help            Hilfe

set -euo pipefail

# === Konfiguration ===
PROJECTS_ROOT="${PROJECTS_ROOT:-$HOME/Development}"
CLAUDE_GLOBAL_DIR="$HOME/.claude"
SUBAGENTS=(architect architect-reviewer developer qa-reviewer security-reviewer test-writer)
AI_CLIS=(claude gemini codex)   # optionale KI-CLIs, nur Soft-Check in --check
OS="$(uname)"
BEADS_INSTALL_URL="https://raw.githubusercontent.com/gastownhall/beads/main/scripts/install.sh"

# === Ausgabe-Helfer ===
log()  { printf '%s\n' "  -> $1"; }
ok()   { printf '%s\n' "  [ok] $1"; }
info() { printf '%s\n' "  [info] $1"; }
warn() { printf '%s\n' "  [warn] $1" >&2; }
err()  { printf '%s\n' "  [fehler] $1" >&2; exit 1; }

show_help() {
  cat <<'HELP'
tatara — Bootstrap fuer neue Projekte mit Git + Beads + Claude-Workflow.

NUTZUNG
  tatara <NAME> [BESCHREIBUNG]   Neues Projekt unter ~/Development/<NAME> anlegen
  tatara --check                 Globale Voraussetzungen + optionale KI-CLIs pruefen
  tatara --bootstrap-globals     Fehlende globale ~/.claude/* Dateien anlegen
  tatara --snapshot-globals      Aktuelle ~/.claude/* Dateien als Templates ins
                                      Skript zurueckschreiben (Backup als .bak)
  tatara -h | --help             Diese Hilfe

PROJEKT-LAYOUT
  ~/Development/<NAME>/
    .git/                              Git-Repository (default branch main)
    .beads/                            Lokale Beads-DB (stealth, nicht in git)
    .claude/
      settings.json                    PostToolUse-Hook -> post-commit-verify.sh
      hooks/post-commit-verify.sh      Zeigt git show HEAD --stat nach jedem Commit
    .gitignore                         macOS/IDE/Secrets-Standard
    CLAUDE.md                          Projekt-CLAUDE.md mit Build-/Stack-Platzhaltern
    README.md                          Minimal mit Name + Beschreibung

GLOBALE VORAUSSETZUNGEN (geprueft vor jedem Setup)
  Plattform                            macOS oder Linux (Windows: via WSL)
  Paketmanager                         macOS: Homebrew (https://brew.sh)
                                       Linux: apt / dnf / pacman / zypper (oder brew)
  git, bd                              fehlen sie, bietet tatara die Installation an
                                       (bd auf Linux via brew oder offizielles Skript)
  ~/.claude/CLAUDE.md                  Globale Workflow-Regeln
  ~/.claude/software-development-workflow.md
  ~/.claude/agents/<6 Subagenten>.md   architect, architect-reviewer, developer,
                                       qa-reviewer, security-reviewer, test-writer

UMGEBUNGSVARIABLEN
  TATARA_ARCHITECT_MODEL           Architekt-Modell erzwingen: fable | opus
                                   Default: Auto-Erkennung via fable-Verfuegbarkeit
  PROJECTS_ROOT                    Basisverzeichnis fuer neue Projekte
                                   Default: ~/Development

Auf einem neuen Rechner zuerst:
  macOS:  Homebrew installieren (https://brew.sh)
  Linux:  ein Paketmanager (apt/dnf/pacman/zypper) vorhanden
  dann:   tatara --bootstrap-globals
HELP
}

# === Voraussetzungen: Pruefen + Installieren ===
check_bd() {
  command -v bd >/dev/null 2>&1
}

check_git() {
  command -v git >/dev/null 2>&1
}

# Bricht ab, wenn die Plattform nicht unterstuetzt wird.
require_supported_os() {
  case "$OS" in
    Darwin|Linux) : ;;
    *) err "tatara unterstuetzt derzeit macOS und Linux. Windows: bitte via WSL ausfuehren." ;;
  esac
}

# Ja/Nein-Rueckfrage (TTY-robust). Rueckgabe 0 bei Ja.
confirm() {
  local answer=""
  read -rp "  $1 [y/N] " answer || true
  [[ "$answer" == [yY]* ]]
}

# Installiert ein Paket plattformabhaengig.
# $1 Anzeigename, $2 brew-Formula, $3 apt-Pkg, $4 dnf/zypper-Pkg, $5 pacman-Pkg
pkg_install() {
  local name="$1" brewf="$2" aptp="$3" dnfp="$4" pacp="$5"
  case "$OS" in
    Darwin)
      command -v brew >/dev/null 2>&1 \
        || err "$name fehlt und Homebrew ist nicht installiert. Installiere Homebrew: https://brew.sh"
      log "brew install $brewf"
      brew install "$brewf"
      ;;
    Linux)
      if   command -v apt-get >/dev/null 2>&1; then
        log "sudo apt-get install -y $aptp"
        sudo apt-get update -qq && sudo apt-get install -y "$aptp"
      elif command -v dnf >/dev/null 2>&1; then
        log "sudo dnf install -y $dnfp"; sudo dnf install -y "$dnfp"
      elif command -v pacman >/dev/null 2>&1; then
        log "sudo pacman -S --noconfirm $pacp"; sudo pacman -S --noconfirm "$pacp"
      elif command -v zypper >/dev/null 2>&1; then
        log "sudo zypper install -y $dnfp"; sudo zypper install -y "$dnfp"
      elif command -v brew >/dev/null 2>&1; then
        log "brew install $brewf"; brew install "$brewf"
      else
        err "$name fehlt und kein unterstuetzter Paketmanager (apt/dnf/pacman/zypper/brew) gefunden."
      fi
      ;;
  esac
}

# git: ueberall via System-Paketmanager (bzw. brew).
ensure_git() {
  command -v git >/dev/null 2>&1 && return 0
  if [[ "$OS" == Darwin ]]; then
    confirm "git fehlt — via Homebrew installieren?" \
      || err "Abgebrochen — git wird benoetigt. (Alternativ: xcode-select --install)"
  else
    confirm "git fehlt — via System-Paketmanager installieren (sudo)?" \
      || err "Abgebrochen — git wird benoetigt."
  fi
  pkg_install git git git git git
  hash -r 2>/dev/null || true
  command -v git >/dev/null 2>&1 || err "git nach Installation weiterhin nicht gefunden"
  ok "git installiert"
}

# bd: macOS via brew; Linux via brew (falls vorhanden), sonst offizielles
# Beads-Install-Skript (curl | bash). bd ist nicht in apt/dnf/pacman.
ensure_bd() {
  command -v bd >/dev/null 2>&1 && return 0
  if [[ "$OS" == Darwin ]] || command -v brew >/dev/null 2>&1; then
    command -v brew >/dev/null 2>&1 \
      || err "bd fehlt und Homebrew ist nicht installiert. Installiere Homebrew: https://brew.sh"
    confirm "bd fehlt — via 'brew install beads' installieren?" \
      || err "Abgebrochen — bd wird benoetigt."
    log "brew install beads"
    brew install beads
  else
    warn "bd ist nicht in System-Paketmanagern verfuegbar."
    confirm "bd via offizielles Beads-Skript installieren (curl | bash von gastownhall/beads)?" \
      || err "Abgebrochen — bd wird benoetigt. Manuell: npm install -g @beads/bd"
    log "curl -fsSL $BEADS_INSTALL_URL | bash"
    curl -fsSL "$BEADS_INSTALL_URL" | bash
  fi
  hash -r 2>/dev/null || true
  command -v bd >/dev/null 2>&1 \
    || err "bd nach Installation nicht im PATH gefunden — ggf. neue Shell oeffnen und erneut versuchen."
  ok "bd installiert"
}

# shellcheck disable=SC2088  # ~/.claude/... sind Anzeige-Strings (kein Pfad-Expand noetig)
missing_globals() {
  local missing=()
  [[ -f "$CLAUDE_GLOBAL_DIR/CLAUDE.md" ]] || missing+=("~/.claude/CLAUDE.md")
  [[ -f "$CLAUDE_GLOBAL_DIR/software-development-workflow.md" ]] \
    || missing+=("~/.claude/software-development-workflow.md")
  for a in "${SUBAGENTS[@]}"; do
    [[ -f "$CLAUDE_GLOBAL_DIR/agents/$a.md" ]] || missing+=("~/.claude/agents/$a.md")
  done
  if (( ${#missing[@]} )); then printf '%s\n' "${missing[@]}"; fi
}

# stdin -> stdout: ersetzt nur das ERSTE exakte Vorkommen der Zeile 'model: fable'
# durch 'model: opus'. Alle anderen Zeilen (inkl. weiterer Vorkommen) bleiben unveraendert.
substitute_architect_model() {
  awk '!d && $0=="model: fable"{$0="model: opus";d=1}{print}'
}

# Prueft ob fable als Architekt-Modell verfuegbar ist.
# stdout: exakter Slug (available | no-claude | not-logged-in | probe-failed)
# exit:   0 nur bei 'available', sonst 1
# Hinweis: Security: Auth-Daten (claude auth status) werden NIE ausgegeben.
fable_available() {
  if ! command -v claude >/dev/null 2>&1; then
    echo "no-claude"
    return 1
  fi

  local auth_out
  auth_out="$(claude auth status </dev/null 2>/dev/null || true)"

  # loggedIn whitespace-tolerant pruefen
  if ! printf '%s' "$auth_out" | grep -Eq '"loggedIn"[[:space:]]*:[[:space:]]*true'; then
    echo "not-logged-in"
    return 1
  fi

  local probe_out
  probe_out="$(claude -p --model fable --output-format json "ok" </dev/null 2>/dev/null || true)"

  # JSON-Parsing: versuche jq; bei exit 127 (not found) Fallback auf grep.
  # Beide Bool-Felder whitespace-tolerant pruefen.
  local is_ok=0
  local jq_exit
  printf '%s' "$probe_out" | jq -e '.is_error == false and .subtype == "success"' >/dev/null 2>&1
  jq_exit=$?
  if [[ $jq_exit -eq 127 ]]; then
    # jq nicht gefunden -> grep-Fallback
    if printf '%s' "$probe_out" | grep -Eq '"is_error"[[:space:]]*:[[:space:]]*false' \
       && printf '%s' "$probe_out" | grep -Eq '"subtype"[[:space:]]*:[[:space:]]*"success"'; then
      is_ok=1
    fi
  elif [[ $jq_exit -eq 0 ]]; then
    is_ok=1
  fi

  if [[ $is_ok -eq 1 ]]; then
    echo "available"
    return 0
  else
    echo "probe-failed"
    return 1
  fi
}

# Ermittelt das zu nutzende Architekt-Modell.
# stdout: '<modell> <quelle> [<slug>]'  (z.B. 'fable auto' | 'opus fallback no-claude' | 'opus override')
# exit:   0 immer ausser bei ungueltigem TATARA_ARCHITECT_MODEL (dann return 1, kein stdout)
resolve_architect_model() {
  local env_val="${TATARA_ARCHITECT_MODEL:-}"

  if [[ -n "$env_val" ]]; then
    case "$env_val" in
      fable)
        echo "fable override"
        return 0
        ;;
      opus)
        echo "opus override"
        return 0
        ;;
      *)
        # Kein Output hier — Aufrufer gibt Fehlermeldung aus (AK-8-unit: stdout vor EXIT: muss leer sein)
        return 1
        ;;
    esac
  fi

  # Auto-Erkennung via fable_available
  local slug
  slug="$(fable_available)"
  local fa_exit=$?
  if [[ $fa_exit -eq 0 ]]; then
    echo "fable auto"
  else
    echo "opus fallback $slug"
  fi
  return 0
}

mode_check() {
  printf '%s\n' "== Pruefe Voraussetzungen =="
  local fail=0
  if check_git; then
    ok "git installiert ($(git --version 2>/dev/null))"
  else
    warn "git fehlt — wird bei Setup automatisch via brew angeboten"
    fail=1
  fi
  if check_bd; then
    ok "bd installiert ($(bd --version 2>/dev/null | head -1))"
  else
    warn "bd fehlt — wird bei Setup automatisch via brew angeboten"
    fail=1
  fi
  local miss=() line
  while IFS= read -r line; do miss+=("$line"); done < <(missing_globals)
  if [[ ${#miss[@]} -eq 0 ]]; then
    ok "Alle globalen ~/.claude/* Dateien vorhanden"
  else
    warn "Fehlende Globals:"
    for m in "${miss[@]}"; do
      printf '%s\n' "        - $m"
    done
    printf '%s\n' "        -> tatara --bootstrap-globals"
    fail=1
  fi
  # Optionale KI-CLIs (Soft-Check, beeinflusst Exit-Code nicht)
  local cli
  for cli in "${AI_CLIS[@]}"; do
    if command -v "$cli" >/dev/null 2>&1; then
      info "$cli: gefunden"
    else
      info "$cli: nicht gefunden"
    fi
  done

  # Architekt-Modell-Policy (Soft-Check, KEIN claude -p Probe-Call)
  local env_val="${TATARA_ARCHITECT_MODEL:-}"
  if [[ -n "$env_val" ]]; then
    case "$env_val" in
      fable|opus)
        info "Architekt-Modell: $env_val (Quelle: override via TATARA_ARCHITECT_MODEL)"
        ;;
      *)
        warn "TATARA_ARCHITECT_MODEL='$env_val' ist ungueltig — erlaubt: fable, opus"
        fail=1
        ;;
    esac
  else
    if ! command -v claude >/dev/null 2>&1; then
      info "Architekt-Modell: opus (claude nicht verfuegbar)"
    else
      local auth_out
      auth_out="$(claude auth status </dev/null 2>/dev/null || true)"
      if ! printf '%s' "$auth_out" | grep -Eq '"loggedIn"[[:space:]]*:[[:space:]]*true'; then
        info "Architekt-Modell: opus (nicht eingeloggt)"
      else
        info "Architekt-Modell: fable falls verfuegbar, sonst opus (final beim Bootstrap ermittelt)"
      fi
    fi
  fi

  exit $fail
}

# === Mode: bootstrap-globals ===
write_if_missing() {
  local path="$1"
  if [[ -e "$path" ]]; then
    ok "behalten: $path"
    return 1
  fi
  mkdir -p "$(dirname "$path")"
  return 0
}

mode_bootstrap_globals() {
  printf '%s\n' "== Bootstrap globale ~/.claude/* Dateien =="
  mkdir -p "$CLAUDE_GLOBAL_DIR/agents"

  # Architekt-Modell-Policy: Bedarf ermitteln und Policy aufloesen
  local need=0
  if [[ -n "${TATARA_ARCHITECT_MODEL:-}" ]]; then
    need=1
  else
    local a
    for a in "${SUBAGENTS[@]}"; do
      local datei="$CLAUDE_GLOBAL_DIR/agents/$a.md"
      local fn="${a//-/_}"
      if [[ ! -e "$datei" ]]; then
        # Template vollstaendig lesen (SIGPIPE-safe: >/dev/null statt head/grep-Abbruch)
        if "tpl_agent_${fn}" | grep '^model: fable$' >/dev/null 2>&1; then
          need=1
          break
        fi
      fi
    done
  fi

  local effective_model="fable"
  if [[ $need -eq 1 ]]; then
    local policy
    policy="$(resolve_architect_model)" \
      || err "Bootstrap abgebrochen — TATARA_ARCHITECT_MODEL='${TATARA_ARCHITECT_MODEL:-}' ist ungueltig — erlaubt: fable, opus"
    local pol_source pol_reason
    read -r effective_model pol_source pol_reason <<<"$policy"
    info "Architekt-Modell: $effective_model (Quelle: $pol_source${pol_reason:+ — $pol_reason})"
  fi

  if write_if_missing "$CLAUDE_GLOBAL_DIR/CLAUDE.md"; then
    tpl_global_claude_md > "$CLAUDE_GLOBAL_DIR/CLAUDE.md"
    ok "geschrieben: ~/.claude/CLAUDE.md"
  fi
  if write_if_missing "$CLAUDE_GLOBAL_DIR/software-development-workflow.md"; then
    tpl_global_workflow_md > "$CLAUDE_GLOBAL_DIR/software-development-workflow.md"
    ok "geschrieben: ~/.claude/software-development-workflow.md"
  fi
  for a in "${SUBAGENTS[@]}"; do
    local datei="$CLAUDE_GLOBAL_DIR/agents/$a.md"
    local fn="${a//-/_}"
    if write_if_missing "$datei"; then
      if [[ "$effective_model" == "opus" ]]; then
        "tpl_agent_${fn}" | substitute_architect_model > "$datei"
      else
        "tpl_agent_${fn}" > "$datei"
      fi
      ok "geschrieben: ~/.claude/agents/$a.md"
    fi
  done

  printf '%s\n' ""
  ensure_git
  ensure_bd
  printf '%s\n' ""
  printf '%s\n' "Globale Voraussetzungen sind bereit. Nutze 'tatara <name>' fuer ein neues Projekt."
}

# === Mode: snapshot-globals (Skript regeneriert eigene Embedded Templates) ===
mode_snapshot_globals() {
  printf '%s\n' "== Snapshot ~/.claude/* Dateien ins Skript zurueckschreiben =="

  # Pre-Flight: Quellen pruefen
  local missing_count=0
  [[ -f "$CLAUDE_GLOBAL_DIR/CLAUDE.md" ]] \
    || { warn "fehlt: ~/.claude/CLAUDE.md"; missing_count=1; }
  [[ -f "$CLAUDE_GLOBAL_DIR/software-development-workflow.md" ]] \
    || { warn "fehlt: ~/.claude/software-development-workflow.md"; missing_count=1; }
  for a in "${SUBAGENTS[@]}"; do
    [[ -f "$CLAUDE_GLOBAL_DIR/agents/$a.md" ]] \
      || { warn "fehlt: ~/.claude/agents/$a.md"; missing_count=1; }
  done
  (( missing_count )) && err "Snapshot abgebrochen — fehlende Quellen oben."

  # Eigenen Skriptpfad robust ermitteln (folgt Symlink -> Repo-Datei)
  local script
  script="$(realpath "${BASH_SOURCE[0]}")"
  [[ -z "$script" || ! -f "$script" ]] \
    && err "Kann eigenen Skriptpfad nicht bestimmen"

  log "Quelle: ~/.claude/"
  log "Ziel:   $script"

  # Backup
  cp -f "$script" "$script.bak"
  ok "Backup: $script.bak"

  # Neuen Templates-Block in Temp-Datei aufbauen
  local tmpblock tmpscript
  tmpblock="$(mktemp "${TMPDIR:-/tmp}/tatara-block.XXXXXX")"
  {
    printf '%s\n' "# === BEGIN AUTO-SNAPSHOT TEMPLATES ==="
    printf '%s\n' "tpl_global_claude_md() {"
    printf '%s\n' "  cat <<'GLOBAL_CLAUDE_END'"
    cat "$CLAUDE_GLOBAL_DIR/CLAUDE.md"
    printf '%s\n' "GLOBAL_CLAUDE_END"
    printf '%s\n' "}"
    printf '\n'
    printf '%s\n' "tpl_global_workflow_md() {"
    printf '%s\n' "  cat <<'GLOBAL_WORKFLOW_END'"
    cat "$CLAUDE_GLOBAL_DIR/software-development-workflow.md"
    printf '%s\n' "GLOBAL_WORKFLOW_END"
    printf '%s\n' "}"
    for a in "${SUBAGENTS[@]}"; do
      printf '\n'
      local fn="${a//-/_}"
      printf '%s\n' "tpl_agent_${fn}() {"
      printf '%s\n' "  cat <<'AGENT_END'"
      cat "$CLAUDE_GLOBAL_DIR/agents/$a.md"
      printf '%s\n' "AGENT_END"
      printf '%s\n' "}"
    done
    printf '%s\n' "# === END AUTO-SNAPSHOT TEMPLATES ==="
  } > "$tmpblock"

  # Skript zusammensetzen: pre + neuer Block + post
  tmpscript="$(mktemp "${TMPDIR:-/tmp}/tatara-script.XXXXXX")"
  awk -v blockfile="$tmpblock" '
    BEGIN { state = "pre" }
    state == "pre" {
      if ($0 == "# === BEGIN AUTO-SNAPSHOT TEMPLATES ===") {
        while ((getline line < blockfile) > 0) print line
        close(blockfile)
        state = "skip"
        next
      }
      print
      next
    }
    state == "skip" {
      if ($0 == "# === END AUTO-SNAPSHOT TEMPLATES ===") {
        state = "post"
      }
      next
    }
    state == "post" { print }
  ' "$script" > "$tmpscript"

  # Validierung: Marker vorhanden + bash-Syntax-Check
  if ! grep -q "BEGIN AUTO-SNAPSHOT TEMPLATES" "$tmpscript" \
     || ! grep -q "END AUTO-SNAPSHOT TEMPLATES" "$tmpscript"; then
    rm -f "$tmpblock" "$tmpscript"
    err "Validierung fehlgeschlagen — Marker im neuen Skript nicht gefunden. Original unveraendert."
  fi
  if ! bash -n "$tmpscript" 2>/dev/null; then
    rm -f "$tmpblock" "$tmpscript"
    err "Syntax-Check (bash -n) fehlgeschlagen — neues Skript verworfen. Original unveraendert."
  fi

  # Atomic mv
  chmod +x "$tmpscript"
  mv "$tmpscript" "$script"
  rm -f "$tmpblock"

  ok "Snapshot eingespielt"
  printf '%s\n' ""
  printf '%s\n' "Unterschied gegen Backup: diff \"$script.bak\" \"$script\""
}

# === Mode: neues Projekt ===
mode_tatara() {
  local name="$1"
  local desc="${2:-}"

  [[ -z "$name" ]] && err "Projektname erforderlich. Nutze 'tatara -h' fuer Hilfe."
  [[ "$name" == *"/"* ]] && err "Projektname darf kein / enthalten"
  [[ "$name" == *" "* ]] && err "Projektname darf keine Leerzeichen enthalten"
  [[ "$name" == .* ]]    && err "Projektname darf nicht mit . beginnen"

  local target="$PROJECTS_ROOT/$name"
  [[ -e "$target" ]] && err "$target existiert bereits"

  # Pre-Flight
  ensure_git
  ensure_bd
  local miss=() line
  while IFS= read -r line; do miss+=("$line"); done < <(missing_globals)
  if [[ ${#miss[@]} -gt 0 ]]; then
    warn "Globale Voraussetzungen unvollstaendig:"
    for m in "${miss[@]}"; do
      printf '%s\n' "        - $m"
    done
    err "Lauf zuerst: tatara --bootstrap-globals"
  fi

  printf '%s\n' "== Lege Projekt '$name' an =="
  log "Verzeichnis: $target"
  mkdir -p "$target"
  cd "$target"

  log "git init (default branch main)"
  git init -b main -q

  log "Schreibe README.md, CLAUDE.md, .gitignore"
  tpl_readme_md "$name" "$desc" > README.md
  tpl_project_claude_md "$name" "$desc" > CLAUDE.md
  tpl_gitignore > .gitignore

  log "Schreibe .claude/settings.json + post-commit-verify.sh"
  mkdir -p .claude/hooks
  tpl_claude_settings_json > .claude/settings.json
  tpl_post_commit_verify_sh > .claude/hooks/post-commit-verify.sh
  chmod +x .claude/hooks/post-commit-verify.sh

  log "bd init (stealth, skip-hooks, skip-agents)"
  BD_NON_INTERACTIVE=1 bd init \
    --skip-hooks --skip-agents --stealth --role maintainer >/dev/null

  # Stealth-Luecke: bd init traegt .dolt/ + .beads-credential-key in
  # .gitignore ein (versioniert). User-Direktive 'strikt lokal' verlangt
  # frische .gitignore; Schutzfunktion uebernimmt .git/info/exclude.
  # Unconditional ueberschreiben, weil .gitignore vor bd init nie staged
  # wurde -> git diff hat nichts zu vergleichen.
  log "schreibe .gitignore neu (Beads-Stealth-Luecke schliessen)"
  tpl_gitignore > .gitignore

  log "Initial commit"
  git add -A
  git commit -q -m "init: initial project scaffolding"

  printf '%s\n' ""
  ok "Projekt '$name' bereit: $target"
  printf '%s\n' ""
  printf '%s\n' "Naechste Schritte:"
  printf '%s\n' "  cd $target"
  printf '%s\n' "  # Stack/Sprache + Build-Kommandos in CLAUDE.md ergaenzen"
  printf '%s\n' "  # Erste Beads-Issues anlegen: bd create 'Setup XYZ' --type task"
}

# ============================================================================
# Templates — alle als Funktionen mit heredoc
# Block zwischen BEGIN/END AUTO-SNAPSHOT TEMPLATES wird von --snapshot-globals
# byte-genau regeneriert.
# ============================================================================

tpl_readme_md() {
  local name="$1" desc="$2"
  printf '# %s\n\n' "$name"
  [[ -n "$desc" ]] && printf '%s\n\n' "$desc"
  printf '## Setup\n\n_Setup-Schritte fuer dieses Projekt eintragen._\n'
}

tpl_project_claude_md() {
