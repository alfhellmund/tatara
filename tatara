tpl_post_commit_verify_sh() {
  cat <<'HOOK_END'
#!/bin/bash
# Done-Gatekeeping: after every `git commit` via the Bash tool,
# show `git show HEAD --stat` so the commit message can be checked
# against the actual diff. Verhindert False-Positive-Meldungen wie
# "wired up in start_server", wenn lib.rs gar nicht im Commit ist.

set -e

# Tool input is piped in as JSON on stdin.
input=$(cat)

# Only act on Bash commands that contain `git commit`.
command=$(echo "$input" | jq -r '.tool_input.command // empty')
if [[ -z "$command" ]]; then
    exit 0
fi
if ! echo "$command" | grep -qE '(^|[^a-zA-Z])git commit'; then
    exit 0
fi

# Skip `git commit --dry-run` / `git commit --help` etc.
if echo "$command" | grep -qE 'git commit.*(--dry-run|--help|-h[[:space:]]|-h$)'; then
    exit 0
fi

# Use the tool's reported cwd so the hook works across projects.
cwd=$(echo "$input" | jq -r '.cwd // empty')
if [[ -n "$cwd" && -d "$cwd" ]]; then
    cd "$cwd"
fi

# Grab HEAD stat — fail silently if the commit did not actually land
# (e.g. pre-commit hook rejected it).
stat=$(git show HEAD --stat 2>/dev/null || true)
if [[ -z "$stat" ]]; then
    exit 0
fi

# Feed the stat back as additional context so Claude has to look at it
# before declaring the commit successful.
jq -n --arg stat "$stat" '{
  "hookSpecificOutput": {
    "hookEventName": "PostToolUse",
    "additionalContext": ("HEAD-COMMIT STAT (auto-verified via hook — compare against your commit message before declaring \"done\"):\n\n" + $stat)
  }
}'
HOOK_END
}

